APP_NAME=messenger-auth
ENVIRONMENT=development

DB_CONTAINER_NAME=messenger-postgres
DB_DATABASE=messenger
DB_DRIVER=postgresql+psycopg
DB_USERNAME=messenger
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

PGADMIN_CONTAINER_NAME=messenger-pgadmin
PGADMIN_EMAIL=admin@local.test
PGADMIN_PASSWORD=change-me
PGADMIN_PORT=5050
PGADMIN_VOLUME_DATA_NAME=messenger_pgadmin_data

# Common signing policy. OAuth/JWT code sees the same interface in every mode.
TOKEN_SIGNING_BACKEND=local
SIGNING_PROVIDER_NAME=local-primary
SIGNING_ALGORITHM=RS256
INITIAL_KEY_ACTIVATION_POLICY=if_registry_empty

JWT_ISSUER=http://localhost:8000
JWT_AUDIENCE=messenger-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Local-machine default. The directory is Git-ignored and survives restarts.
LOCAL_SIGNING_KEY_DIRECTORY=.local/signing-keys
LOCAL_KEY_BOOTSTRAP_POLICY=generate_if_empty
LOCAL_RSA_KEY_SIZE=2048
LOCAL_SIGNING_STRICT_PERMISSIONS=false

# Reserved for the later VaultTransitSigningProvider implementation.
VAULT_ADDR=http://localhost:8200
VAULT_TRANSIT_MOUNT=transit
VAULT_JWT_KEY_NAME=auth-jwt
# VAULT_TOKEN_FILE=/run/secrets/vault-token
